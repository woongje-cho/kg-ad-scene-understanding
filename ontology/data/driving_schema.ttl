@prefix : <http://www.semanticweb.org/driving-ontology/2026/3#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/driving-ontology/2026/3> rdf:type owl:Ontology .

:TopologicalObject rdf:type owl:Class .
:PhysicalObject rdf:type owl:Class .
:Agent rdf:type owl:Class .
:Quality rdf:type owl:Class .
:Affordance rdf:type owl:Class .
:Attribute rdf:type owl:Class .
:Environment rdf:type owl:Class .
:RoadNetwork rdf:type owl:Class .
:District rdf:type owl:Class .
:Zone rdf:type owl:Class .
:Intersection rdf:type owl:Class .
:LaneSegment rdf:type owl:Class .
:HighwaySection rdf:type owl:Class .
:ParkingArea rdf:type owl:Class .
:SchoolZone rdf:type owl:Class .
:MergeZone rdf:type owl:Class .
:Connection rdf:type owl:Class .
:LaneConnection rdf:type owl:Class .
:IntersectionEntry rdf:type owl:Class .
:Object rdf:type owl:Class .
:Vehicle rdf:type owl:Class .
:Car rdf:type owl:Class .
:Truck rdf:type owl:Class .
:Bus rdf:type owl:Class .
:Motorcycle rdf:type owl:Class .
