:TrafficSign rdf:type owl:Class .
:SpeedLimitSign rdf:type owl:Class .
:StopSign rdf:type owl:Class .
:YieldSign rdf:type owl:Class .
:NoParkingSign rdf:type owl:Class .
:LaneMergeSign rdf:type owl:Class .
:SchoolZoneSign rdf:type owl:Class .
:Pedestrian rdf:type owl:Class .
:AdultPedestrian rdf:type owl:Class .
:ChildPedestrian rdf:type owl:Class .
:ElderlyPedestrian rdf:type owl:Class .
:Obstacle rdf:type owl:Class .
:ConstructionCone rdf:type owl:Class .
:Debris rdf:type owl:Class .
:Infrastructure rdf:type owl:Class .
:Guardrail rdf:type owl:Class .
:Crosswalk rdf:type owl:Class .
:BusStop rdf:type owl:Class .
:Median rdf:type owl:Class .
:EgoVehicle rdf:type owl:Class .
:Human rdf:type owl:Class .
:Passable rdf:type owl:Class .
:Overtakable rdf:type owl:Class .
:Stoppable rdf:type owl:Class .
:Avoidable rdf:type owl:Class .
:Dangerous rdf:type owl:Class .
:inZone rdf:type owl:ObjectProperty .
:hasObject rdf:type owl:ObjectProperty .
:isZoneOf rdf:type owl:ObjectProperty .
:isDistrictOf rdf:type owl:ObjectProperty .
:hasZone rdf:type owl:ObjectProperty .
:hasDistrict rdf:type owl:ObjectProperty .
:connectsTo rdf:type owl:ObjectProperty .
:hasConnection rdf:type owl:ObjectProperty .
:isConnectionOf rdf:type owl:ObjectProperty .
:hasAffordance rdf:type owl:ObjectProperty .
:hasSpatialPart rdf:type owl:ObjectProperty .
:isSpatialPartOf rdf:type owl:ObjectProperty .
:hasPathTo rdf:type owl:ObjectProperty .
:inSpace rdf:type owl:ObjectProperty .
:x rdf:type owl:DatatypeProperty .
:y rdf:type owl:DatatypeProperty .
:z rdf:type owl:DatatypeProperty .
:speed rdf:type owl:DatatypeProperty .
:speedLimit rdf:type owl:DatatypeProperty .
:state rdf:type owl:DatatypeProperty .
:isOpen rdf:type owl:DatatypeProperty .
:isObstacle rdf:type owl:DatatypeProperty .

:RoadNetwork rdfs:subClassOf :Environment .
:District rdfs:subClassOf :Environment .
:Zone rdfs:subClassOf :Environment .
:Zone rdfs:subClassOf :TopologicalObject .
:Intersection rdfs:subClassOf :Zone .
:LaneSegment rdfs:subClassOf :Zone .
:HighwaySection rdfs:subClassOf :Zone .
:ParkingArea rdfs:subClassOf :Zone .
:SchoolZone rdfs:subClassOf :Zone .
:MergeZone rdfs:subClassOf :Zone .
:Connection rdfs:subClassOf :TopologicalObject .
:Connection rdfs:subClassOf :PhysicalObject .
:LaneConnection rdfs:subClassOf :Connection .
:IntersectionEntry rdfs:subClassOf :Connection .
:Object rdfs:subClassOf :PhysicalObject .
:Vehicle rdfs:subClassOf :Object .
:Car rdfs:subClassOf :Vehicle .
:Truck rdfs:subClassOf :Vehicle .
:Bus rdfs:subClassOf :Vehicle .
:Motorcycle rdfs:subClassOf :Vehicle .
:Bicycle rdfs:subClassOf :Vehicle .
:EmergencyVehicle rdfs:subClassOf :Vehicle .
:ParkedVehicle rdfs:subClassOf :Vehicle .
:TrafficControl rdfs:subClassOf :Object .
:TrafficLight rdfs:subClassOf :TrafficControl .
:TrafficSign rdfs:subClassOf :TrafficControl .
:SpeedLimitSign rdfs:subClassOf :TrafficSign .
:StopSign rdfs:subClassOf :TrafficSign .
:YieldSign rdfs:subClassOf :TrafficSign .
:NoParkingSign rdfs:subClassOf :TrafficSign .
:LaneMergeSign rdfs:subClassOf :TrafficSign .
:SchoolZoneSign rdfs:subClassOf :TrafficSign .
:Pedestrian rdfs:subClassOf :Object .
:AdultPedestrian rdfs:subClassOf :Pedestrian .
:ChildPedestrian rdfs:subClassOf :Pedestrian .
:ElderlyPedestrian rdfs:subClassOf :Pedestrian .
:Obstacle rdfs:subClassOf :Object .
:ConstructionCone rdfs:subClassOf :Obstacle .
:Debris rdfs:subClassOf :Obstacle .
:Infrastructure rdfs:subClassOf :Object .
:Guardrail rdfs:subClassOf :Infrastructure .
:Crosswalk rdfs:subClassOf :Infrastructure .
:BusStop rdfs:subClassOf :Infrastructure .
:Median rdfs:subClassOf :Infrastructure .
:EgoVehicle rdfs:subClassOf :Agent .
:EgoVehicle rdfs:subClassOf :Vehicle .
:Human rdfs:subClassOf :Agent .
:Affordance rdfs:subClassOf :Quality .
:Attribute rdfs:subClassOf :Quality .
:Passable rdfs:subClassOf :Affordance .
:Overtakable rdfs:subClassOf :Affordance .
:Stoppable rdfs:subClassOf :Affordance .
:Avoidable rdfs:subClassOf :Affordance .
:Dangerous rdfs:subClassOf :Affordance .

[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :RoadNetwork :District :Zone ) .
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Environment :Quality ) .
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :PhysicalObject :Quality ) .

:isZoneOf rdfs:subPropertyOf :isSpatialPartOf .
:isDistrictOf rdfs:subPropertyOf :isSpatialPartOf .
:isConnectionOf rdfs:subPropertyOf :hasPathTo .
:isZoneOf owl:propertyChainAxiom ( :isConnectionOf :isZoneOf ) .


:hasObject owl:inverseOf :inZone .
:hasZone owl:inverseOf :isZoneOf .
:hasDistrict owl:inverseOf :isDistrictOf .

:connectsTo rdf:type owl:SymmetricProperty .
:hasSpatialPart rdf:type owl:TransitiveProperty .
:isSpatialPartOf rdf:type owl:TransitiveProperty .
:x rdf:type owl:FunctionalProperty .
:y rdf:type owl:FunctionalProperty .
:z rdf:type owl:FunctionalProperty .
:isOpen rdf:type owl:FunctionalProperty .

:inZone rdfs:domain :Object .
:isZoneOf rdfs:domain :Zone .
:isDistrictOf rdfs:domain :District .
:isConnectionOf rdfs:domain :Connection .
:hasAffordance rdfs:domain :PhysicalObject .
:inZone rdfs:range :Zone .
:isZoneOf rdfs:range :District .
:isDistrictOf rdfs:range :RoadNetwork .
:isConnectionOf rdfs:range :Zone .
:hasAffordance rdfs:range :Affordance .
:isOpen rdfs:domain :Connection .
:isOpen rdfs:range xsd:boolean .
:x rdfs:range xsd:float .
:y rdfs:range xsd:float .
:z rdfs:range xsd:float .
:speed rdfs:range xsd:int .
:speedLimit rdfs:range xsd:int .
